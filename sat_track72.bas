3295 IF ABS(C2) < 0.001 THEN C2 = 0.001: REM ADDED BY MARCOEXO : PREVENT DIVISION BY ZERO
3300 IF C3=0 AND C2<0 THEN C4=PI :REM 180 DEGREES
